# API 密钥配置
# 选择其中一个配置即可，推荐使用天行数据

# 天行数据 API Key（推荐）
# 注册地址：https://www.tianapi.com/
# 免费额度：每分钟3次调用
TIANAPI_KEY=

# 聚合数据 API Key（备选）
# 注册地址：https://www.juhe.cn/
# 免费额度：每天100次调用
JUHE_API_KEY=

# 高德地图 API Key（位置服务）
# 注册地址：https://console.amap.com/
# 免费额度：每天300,000次调用（远高于腾讯地图的10,000次）
# 用途：逆地理编码（根据经纬度获取城市名称）
AMAP_API_KEY=

# 腾讯地图 API Key（已弃用，改用高德地图）
# 保留此配置仅作参考，实际项目使用高德地图
TENCENT_MAP_API_KEY=

# 微信小程序配置
WECHAT_APPID=
WECHAT_SECRET=

# 微信订阅消息模板ID
# 后端使用（NestJS）
WECHAT_SUBSCRIBE_TEMPLATE_ID=
# 前端使用（Taro，需要 TARO_APP_ 前缀）
TARO_APP_WECHAT_SUBSCRIBE_TEMPLATE_ID=

# JWT 认证配置
# JWT 签名密钥（生产环境请使用强密码，至少 32 位）
JWT_SECRET=
# Access Token 过期时间（默认 15 分钟）
JWT_ACCESS_TOKEN_EXPIRATION=15m
# Refresh Token 过期时间（默认 7 天）
JWT_REFRESH_TOKEN_EXPIRATION=7d

# 注意：
# 1. 油价数据只需配置 TIANAPI_KEY 或 JUHE_API_KEY 其中一个即可，建议使用天行数据
# 2. 高德地图 API Key 用于位置服务，需要单独配置
# 3. 微信小程序配置用于登录和订阅消息功能
# 4. JWT 配置用于接口认证，生产环境必须配置强密码
# 5. 配置后请重启服务
# 6. 如果未配置，相关功能将不可用

