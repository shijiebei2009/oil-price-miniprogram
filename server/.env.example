# 天聚数行数据（油价查询）
TIANAPI_KEY=your_tianapi_key_here

# 聚合数据（油价查询）
JUHE_API_KEY=your_juhe_api_key_here

# 高德地图 API Key（位置服务）
AMAP_API_KEY=your_amap_api_key_here

# 腾讯地图 API Key（已弃用，改用高德地图）
TENCENT_MAP_API_KEY=your_tencent_map_api_key_here

# 微信小程序配置
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here
WECHAT_SUBSCRIBE_TEMPLATE_ID=your_wechat_subscribe_template_id_here

# 注意：
# 1. 本文件仅为示例模板，实际配置请使用根目录的 .env 文件
# 2. NestJS 会从项目根目录读取 .env 文件
# 3. 不要在本文件中配置真实的密钥
